{
  "manifest_version": 3,
  "name": "Tarjama – English to Darija Translator",
  "version": "1.0",
  "description": "Translate between English, French, Spanish, Arabic and Moroccan Darija in a side panel.",
  "permissions": [
    "sidePanel",
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Tarjama – Translate to Darija"
  }
}
